PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
JWT_SECRET=change-me-to-a-random-string
# Database (required in production — use PostgreSQL on Render)
DATABASE_URL="postgresql://onepage:onepagepassword@localhost:5432/onepagedb?schema=public"
# On Render: set DATABASE_URL to your Postgres Internal Connection String
# (Environment → add variable, or link the database under Connections)

# Optional — image uploads via Cloudinary
CLOUDINARY_NAME=
CLOUDINARY_KEY=
CLOUDINARY_SECRET=

# Optional — AI bio generation
OPENAI_API_KEY=

# Optional — contact form email delivery (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
